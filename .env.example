APP_NAME=81-maktab
# LOCAL: local | HOST (production): production
APP_ENV=local
APP_KEY=
# MUHIM: Hostda APP_DEBUG=false qiling (xavfsizlik uchun)!
APP_DEBUG=true
# Host domeningizni yozing (masalan: https://81maktab.uz)
APP_URL=http://localhost

# AI: o‘zingiz yozgan javobni qaytarish (mock). Hostda faqat admin + AI_LOCAL_MOCK_ON_HOST=true
AI_LOCAL_MOCK=false
AI_LOCAL_MOCK_ON_HOST=false
# Google Gemini (bo‘lmasa ichki ma’lumotlar + fallback ishlaydi)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# AI taqvim javobi: bitta savoldagi tadbirlar soni va tavsif uzunligi
AI_CALENDAR_MAX_EVENTS=15
AI_CALENDAR_MAX_BODY_CHARS=280
APP_TIMEZONE=Asia/Tashkent
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_DELIVERY_ENABLED=true
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_TIMEOUT=15
MAIL_EHLO_DOMAIN=
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Cloudflare Turnstile (https://dash.cloudflare.com/) — bot himoyasi
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Sentry xatolarni kuzatish (https://sentry.io) — composer update qilgach: php artisan sentry:publish
SENTRY_LARAVEL_DSN=

# Spatie backup: kunlik zip (storage/app/Laravel) — serverda yoqish
BACKUP_SCHEDULE_ENABLED=false
