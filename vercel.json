{
    "version": 2,
    "framework": null,
    "installCommand": "composer install --no-dev --optimize-autoloader --ignore-platform-reqs",
    "buildCommand": "php artisan config:cache && php artisan route:cache && php artisan view:cache || true",
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/build/$1"
        },
        {
            "src": "/storage/(.*)",
            "dest": "/storage/$1"
        },
        {
            "src": "/(css|js|images|fonts|favicon\\.ico|robots\\.txt|sitemap\\.xml)(.*)",
            "dest": "/$1$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "SESSION_DRIVER": "cookie",
        "CACHE_DRIVER": "array",
        "LOG_CHANNEL": "stderr"
    }
}
